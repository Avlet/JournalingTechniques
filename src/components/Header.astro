---
// src/components/Header.astro
const top6Techniques = [
  "Gratitude Journaling", "Morning Pages", "Bullet Journaling", 
  "Stream of Consciousness", "Expressive Writing", "Dream Journaling"
];
---

<header class="fixed top-0 left-0 right-0 z-50 flex justify-center p-6 pointer-events-none">
  <nav class="pointer-events-auto bg-white/80 backdrop-blur-xl shadow-[0_8px_32px_rgba(0,0,0,0.05)] border border-white/20 rounded-full px-2 py-2 flex items-center justify-between w-full max-w-6xl transition-all duration-500 hover:shadow-indigo-500/10">
    
    <!-- Logo Section -->
    <a href="/" class="flex items-center gap-2.5 pl-5 pr-4 group h-10">
      <div class="relative flex items-center justify-center">
        <div class="absolute inset-0 bg-indigo-500 rounded-full blur-md opacity-20 group-hover:opacity-50 transition-opacity"></div>
        <span class="relative block w-4 h-4 rounded-full bg-gradient-to-tr from-indigo-600 to-violet-600 shadow-inner"></span>
      </div>
      <span class="font-black text-slate-900 tracking-tighter text-xl leading-none">Journaling<span class="text-indigo-600">.</span></span>
    </a>

    <!-- Nav Links Container: Max-width optimize kiya hai -->
    <div class="hidden lg:flex items-center bg-slate-100/60 rounded-full p-1">
      <ul class="flex items-center text-sm font-bold text-slate-600 h-9">
        <li><a href="#benefits" class="nav-item">Benefits</a></li>
        
        <!-- Dropdown Technique -->
        <li class="relative group h-full">
          <button class="nav-item h-full flex items-center gap-1.5 outline-none whitespace-nowrap">
            <span>Techniques</span>
            <svg class="w-3 h-3 translate-y-[0.5px] transition-transform duration-300 group-hover:rotate-180 text-slate-400 group-hover:text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          
          <div class="absolute top-[calc(100%+12px)] left-1/2 -translate-x-1/2 w-64 bg-white/95 backdrop-blur-2xl border border-slate-100 shadow-2xl rounded-[28px] opacity-0 invisible group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 translate-y-4 transition-all duration-300 overflow-hidden p-2">
              {top6Techniques.map(tech => (
                <a href={`/technique/${tech.toLowerCase().replace(/ /g, '-')}`} class="flex items-center px-4 py-3 rounded-[18px] text-sm text-slate-600 hover:bg-indigo-50 hover:text-indigo-600 transition-all font-medium group/item">
                  <span class="w-1.5 h-1.5 rounded-full bg-slate-200 mr-3 group-hover/item:bg-indigo-500 transition-colors"></span>
                  {tech}
                </a>
              ))}
          </div>
        </li>
        
        <li><a href="/blog" class="nav-item">Blog</a></li>
        <li><a href="/about" class="nav-item">About</a></li>
        <!-- Contact Us added back -->
        <li><a href="/contact" class="nav-item">Contact Us</a></li>
      </ul>
    </div>

    <!-- Action Button -->
    <div class="pr-1">
      <a href="/contact" class="hidden md:flex items-center justify-center gap-2 bg-slate-900 text-white px-5 h-10 rounded-full text-[10px] font-black uppercase tracking-[0.15em] hover:bg-indigo-600 transition-all duration-300 active:scale-95 shadow-lg shadow-slate-200 group/btn">
        Start Writing
        <svg class="w-3 h-3 -rotate-45 group-hover/btn:rotate-0 transition-transform duration-300" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="4">
          <path d="M5 12h14m-7-7 7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </nav>
</header>

<style>
  @reference "../styles/global.css";

  .nav-item {
    /* Padding thoda kam kiya hai (px-4) taaki Contact Us fit ho jaye */
    @apply px-4 rounded-full transition-all duration-300 flex items-center justify-center text-slate-500 whitespace-nowrap;
    height: 100%;
  }

  .nav-item:hover {
    @apply text-indigo-600 bg-white shadow-sm;
  }

  /* Scroll effect logic */
  header.scrolled nav {
    @apply max-w-3xl py-1.5 px-1.5;
  }
</style>

<script>
  const header = document.querySelector('header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  });
</script>
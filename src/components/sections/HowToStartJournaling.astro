---
// src/components/sections/HowToStartJournaling.astro
---

<section id="how-to-start" class="py-16 md:py-24 px-4 md:px-10 lg:px-20 max-w-7xl mx-auto overflow-hidden">
  <div class="text-center mb-12 md:mb-20 relative">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-10 w-48 h-48 md:w-64 md:h-64 bg-indigo-200/20 blur-[80px] md:blur-[100px] -z-10"></div>
    
    <span class="inline-block bg-indigo-50 text-indigo-600 px-4 py-1.5 rounded-full text-[10px] md:text-xs font-bold uppercase tracking-[0.2em] mb-4 md:mb-6">
      Getting Started
    </span>
    
    <h2 class="text-3xl md:text-6xl font-black text-slate-900 mb-4 md:mb-6 tracking-tight leading-tight px-2">
      How to Start your <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-purple-600">Practice</span>
    </h2>
    
    <p class="text-slate-500 text-base md:text-xl max-w-2xl mx-auto leading-relaxed px-4">
      Every experienced journaler started exactly where you are now: staring at a blank page.
    </p>
  </div>

  <div class="group relative bg-white border border-slate-100 rounded-3xl p-6 md:p-14 shadow-2xl shadow-slate-200/50 mb-8 md:mb-12 overflow-hidden transition-all duration-500 hover:border-indigo-200">
    <div class="absolute -top-24 -right-24 w-64 h-64 bg-indigo-50 rounded-full blur-3xl group-hover:bg-indigo-100/50 transition-colors duration-700"></div>

    <div class="relative z-10">
      <div class="flex flex-col md:flex-row items-start md:items-center gap-4 md:gap-6 mb-8 md:mb-12">
        <span class="bg-slate-900 text-white font-black w-12 h-12 md:w-14 md:h-14 flex items-center justify-center rounded-2xl text-lg md:text-xl shadow-lg">01</span>
        <h3 class="text-2xl md:text-4xl font-bold text-slate-800 tracking-tight">Choose Your Format First</h3>
      </div>
      
      <p class="text-slate-500 mb-8 md:mb-12 text-base md:text-xl max-w-3xl leading-relaxed">
        Decide where your thoughts live. Consistency is more important than the medium.
      </p>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-8">
        <div class="group/item relative p-6 md:p-8 rounded-2xl bg-slate-50 border border-slate-100 transition-all duration-500 hover:bg-white hover:shadow-xl hover:-translate-y-1">
          <div class="w-10 h-10 md:w-12 md:h-12 bg-indigo-100 text-indigo-600 rounded-xl flex items-center justify-center mb-6 group-hover/item:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.375 2.625a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4Z"></path></svg>
          </div>
          <h4 class="font-bold text-lg md:text-xl text-slate-800 mb-4">Paper Journaling</h4>
          <ul class="space-y-3">
            {['Activates neural pathways', 'Tactile processing', 'Zero distractions'].map(item => (
              <li class="flex items-center gap-3 text-slate-500 text-sm">
                <span class="w-1.5 h-1.5 rounded-full bg-indigo-400 shrink-0"></span> {item}
              </li>
            ))}
          </ul>
        </div>

        <div class="group/item relative p-6 md:p-8 rounded-2xl bg-slate-50 border border-slate-100 transition-all duration-500 hover:bg-white hover:shadow-xl hover:-translate-y-1">
          <div class="w-10 h-10 md:w-12 md:h-12 bg-emerald-100 text-emerald-600 rounded-xl flex items-center justify-center mb-6 group-hover/item:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"></rect><path d="M12 18h.01"></path></svg>
          </div>
          <h4 class="font-bold text-lg md:text-xl text-slate-800 mb-4">Digital Journaling</h4>
          <ul class="space-y-3">
            {['Searchable & accessible', 'Encrypted privacy', 'Mood tracking'].map(item => (
              <li class="flex items-center gap-3 text-slate-500 text-sm">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 shrink-0"></span> {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-8">
    {[
      { step: '02', color: 'indigo', title: 'Start Tiny', desc: 'Three sentences. That is a complete session. Let the habit lead the length.' },
      { step: '03', color: 'emerald', title: '30-Day Rule', desc: 'One technique, 30 days. Mastery beats variety every single time.' },
      { step: '04', color: 'orange', title: 'Habit Stacking', desc: 'Tie it to your morning coffee. The old habit pulls the new one along.' }
    ].map(item => (
      <div class="group relative bg-white border border-slate-100 rounded-3xl p-8 md:p-10 transition-all duration-500 hover:shadow-xl hover:-translate-y-1">
          <span class={`bg-${item.color}-50 text-${item.color}-600 font-bold px-4 py-1 rounded-full text-[10px] mb-6 inline-block uppercase tracking-widest`}>
            Step {item.step}
          </span>
          <h4 class="text-xl md:text-2xl font-bold text-slate-800 mb-4">{item.title}</h4>
          <p class="text-slate-500 leading-relaxed text-sm md:text-base">{item.desc}</p>
      </div>
    ))}
  </div>
</section>
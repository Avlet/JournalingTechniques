---
// src/components/sections/Consistency.astro
---
<section class="py-15 px-6 bg-[#fafafa]">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-16">
      <span class="text-indigo-600 text-xs font-bold tracking-[0.2em] uppercase mb-4 block">The Hard Part</span>
      <h2 class="text-4xl font-bold text-slate-800 tracking-tight">How to Stay Consistent</h2>
    </div>

    <!-- Container for Hover Group Effect -->
    <div class="space-y-6 group/container">
      {[
        { n: "01", t: "Start with two minutes", d: "Not twenty. Not ten. Two. Set a timer. Once two minutes feels easy, move to five." },
        { n: "02", t: "Reduce friction to near zero", d: "Keep your journal on your nightstand the night before. Put your favorite app on your home screen." }
      ].map(item => (
        <div class="bg-white p-8 md:p-10 rounded-[32px] border border-slate-100 shadow-sm flex flex-col md:flex-row gap-6 md:gap-10 transition-all duration-500 hover:scale-[1.02] hover:shadow-lg group-hover/container:opacity-50 hover:!opacity-100 cursor-pointer overflow-hidden relative">
          
          <!-- Animated Number Background -->
          <span class="text-indigo-600/10 font-black text-7xl absolute -left-2 -bottom-4 select-none pointer-events-none transition-all duration-500 group-hover:scale-125 group-hover:text-indigo-600/20">
            {item.n}
          </span>

          <!-- Actual Number Circle -->
          <div class="relative z-10 flex-shrink-0 w-12 h-12 rounded-full bg-indigo-600 flex items-center justify-center text-white font-bold shadow-md shadow-indigo-200">
            {item.n}
          </div>

          <div class="relative z-10">
            <h3 class="text-xl font-bold text-slate-800 mb-3 group-hover:text-indigo-600 transition-colors">{item.t}</h3>
            <p class="text-slate-500 leading-relaxed text-base max-w-2xl">{item.d}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
---
// src/components/sections/Comparison.astro
---
<section class="py-24 px-6 bg-[#fafafa] overflow-hidden">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16 relative">
      <span class="text-indigo-600 text-xs font-bold tracking-[0.2em] uppercase mb-4 block">The Debate</span>
      <h2 class="text-4xl font-bold text-slate-800">Digital vs. Paper: Which Is Actually Better?</h2>
    </div>

    <div class="relative grid md:grid-cols-2 gap-12 items-stretch mb-16">
      
      <!-- VS Badge -->
      <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 z-20 hidden md:flex items-center justify-center w-14 h-14 bg-white border-4 border-[#fafafa] shadow-xl rounded-full">
          <span class="text-slate-400 font-black text-sm italic">VS</span>
      </div>

      <!-- Paper Side -->
      <div class="comparison-card group relative bg-white p-10 rounded-[40px] border border-slate-100 shadow-sm transition-all duration-500 hover:-translate-y-2 overflow-hidden cursor-pointer">
          <!-- Mouse Glow Effect Layer -->
          <div class="glow-bg absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" style="background: radial-gradient(600px circle at var(--x) var(--y), rgba(79, 70, 229, 0.06), transparent 40%);"></div>

          <div class="flex items-center gap-4 mb-8 relative z-10">
              <div class="bg-indigo-600 p-3 rounded-2xl text-white shadow-lg shadow-indigo-200 transition-transform group-hover:rotate-12">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.375 2.625a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4Z"></path></svg>
              </div>
              <h3 class="text-2xl font-bold text-slate-800">The Case for Paper</h3>
          </div>

          <ul class="space-y-6 relative z-10">
              <li class="flex items-start gap-4 group/item">
                  <div class="mt-1 w-6 h-6 rounded-full bg-indigo-50 flex items-center justify-center flex-shrink-0 group-hover/item:bg-indigo-600 transition-colors">
                    <span class="text-indigo-600 group-hover/item:text-white text-xs">✓</span>
                  </div>
                  <span class="text-slate-500 leading-relaxed"><strong class="text-slate-800 block mb-1">Neurological engagement</strong> Handwriting activates unique neural pathways for deeper connection.</span>
              </li>
              <li class="flex items-start gap-4 group/item">
                  <div class="mt-1 w-6 h-6 rounded-full bg-indigo-50 flex items-center justify-center flex-shrink-0 group-hover/item:bg-indigo-600 transition-colors">
                    <span class="text-indigo-600 group-hover/item:text-white text-xs">✓</span>
                  </div>
                  <span class="text-slate-500 leading-relaxed"><strong class="text-slate-800 block mb-1">Zero distractions</strong> No notifications. Just you and the pen in a fully immersive experience.</span>
              </li>
          </ul>
      </div>

      <!-- Digital Side -->
      <div class="comparison-card group relative bg-white p-10 rounded-[40px] border border-slate-100 shadow-sm transition-all duration-500 hover:-translate-y-2 overflow-hidden cursor-pointer">
          <!-- Mouse Glow Effect Layer -->
          <div class="glow-bg absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" style="background: radial-gradient(600px circle at var(--x) var(--y), rgba(16, 185, 129, 0.06), transparent 40%);"></div>

          <div class="flex items-center gap-4 mb-8 relative z-10">
              <div class="bg-emerald-500 p-3 rounded-2xl text-white shadow-lg shadow-emerald-100 transition-transform group-hover:-rotate-12">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"></rect><path d="M12 18h.01"></path></svg>
              </div>
              <h3 class="text-2xl font-bold text-slate-800">The Case for Digital</h3>
          </div>

          <ul class="space-y-6 relative z-10">
              <li class="flex items-start gap-4 group/item">
                  <div class="mt-1 w-6 h-6 rounded-full bg-emerald-50 flex items-center justify-center flex-shrink-0 group-hover/item:bg-emerald-500 transition-colors">
                    <span class="text-emerald-500 group-hover/item:text-white text-xs">✓</span>
                  </div>
                  <span class="text-slate-500 leading-relaxed"><strong class="text-slate-800 block mb-1">Always accessible</strong> Your phone is always with you. Capture fleeting thoughts immediately.</span>
              </li>
              <li class="flex items-start gap-4 group/item">
                  <div class="mt-1 w-6 h-6 rounded-full bg-emerald-50 flex items-center justify-center flex-shrink-0 group-hover/item:bg-emerald-500 transition-colors">
                    <span class="text-emerald-500 group-hover/item:text-white text-xs">✓</span>
                  </div>
                  <span class="text-slate-500 leading-relaxed"><strong class="text-slate-800 block mb-1">Searchable History</strong> Instantly find specific memories or track mood patterns in seconds.</span>
              </li>
          </ul>
      </div>

    </div>

    <!-- Final Verdict -->
    <!-- Final Verdict (Simple & Minimalist) -->
<div class="relative bg-white border border-slate-100 rounded-[32px] p-10 text-center shadow-sm group transition-all duration-300 hover:shadow-md">
    <!-- Left Accent Line -->
    <div class="absolute left-0 top-1/2 -translate-y-1/2 w-1.5 h-12 bg-indigo-500 rounded-r-full opacity-0 group-hover:opacity-100 transition-all duration-300"></div>
    
    <p class="relative z-10 text-slate-500 text-lg md:text-xl italic leading-relaxed max-w-3xl mx-auto">
        "Consistency matters far more than the medium. 
        <span class="text-slate-800 font-bold not-italic">
            An imperfect journaling habit is infinitely better than a perfect plan that never happens.
        </span>"
    </p>
</div>
  </div>
</section>

<script>
  // Mouse Follower Logic
  const cards = document.querySelectorAll('.comparison-card');
  
  cards.forEach(card => {
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      
      // CSS variables update kar rahe hain jo inline-gradient mein use ho rahi hain
      card.style.setProperty('--x', `${x}px`);
      card.style.setProperty('--y', `${y}px`);
    });
  });
</script>

<style>
  /* Smooth transition for the glow */
  .glow-bg {
    transition: opacity 0.5s ease;
    will-change: background;
  }
</style>
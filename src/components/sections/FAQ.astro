---
// src/components/sections/FAQ.astro
const faqs = [
  { q: "How long should a journal entry be?", a: "There is no set length. It can be a single sentence or multiple pages." },
  { q: "Do I have to write every day?", a: "Consistency is key, but missing a day is fine. Aim for 4-5 times a week." },
  { q: "What if I don't know what to write?", a: "Use prompts or simply start with 'Right now, I am thinking about...'" }
];
---
<section class="py-24 px-6 max-w-4xl mx-auto">
  <div class="text-center mb-16">
    <span class="text-indigo-600 text-xs font-bold tracking-[0.2em] uppercase mb-4 block">Questions</span>
    <h2 class="text-4xl font-bold text-slate-800">Frequently Asked Questions</h2>
  </div>

  <div class="space-y-4">
    {faqs.map(faq => (
      <details class="group bg-white border border-slate-100 rounded-3xl p-6 transition-all">
        <summary class="list-none flex justify-between items-center cursor-pointer font-bold text-slate-700 text-lg">
          {faq.q}
          <span class="text-2xl font-light text-slate-300 group-open:rotate-45 transition-transform">+</span>
        </summary>
        <p class="mt-6 text-slate-400 text-sm leading-relaxed border-t border-slate-50 pt-6">
          {faq.a}
        </p>
      </details>
    ))}
  </div>
</section>
---
// src/components/sections/FAQ.astro
const faqs = [
  { q: "How long should a journal entry be?", a: "There is no set length. It can be a single sentence or multiple pages. The goal is expression, not word count. Even a two-minute session is a success." },
  { q: "Do I have to write every day?", a: "Consistency is key, but missing a day is fine. Aim for 4-5 times a week to build the habit without feeling pressured. Quality of reflection matters more than frequency." },
  { q: "What if I don't know what to write?", a: "Use prompts or simply start with 'Right now, I am thinking about...' or 'Today was...'. The act of writing anything often unlocks deeper thoughts automatically." }
];
---
<section class="py-24 px-6 max-w-4xl mx-auto">
  <div class="text-center mb-16">
    <span class="text-indigo-600 text-xs font-bold tracking-[0.2em] uppercase mb-4 block">Questions</span>
    <h2 class="text-4xl font-bold text-slate-800 tracking-tight">Frequently Asked Questions</h2>
  </div>

  <div class="space-y-4">
    {faqs.map(faq => (
      /* FAQ Card with transition and hover border */
      <details class="group bg-white border border-slate-100 rounded-[24px] p-2 transition-all duration-300 hover:border-indigo-100 hover:shadow-md [&_summary::-webkit-details-marker]:hidden">
        
        <summary class="flex justify-between items-center cursor-pointer p-6 list-none outline-none">
          <span class="font-bold text-slate-700 text-lg transition-colors group-hover:text-indigo-600 group-open:text-indigo-600">
            {faq.q}
          </span>
          
          <!-- Plus/Minus Icon Animation -->
          <div class="relative flex items-center justify-center w-8 h-8 rounded-full bg-slate-50 group-hover:bg-indigo-50 group-open:bg-indigo-600 transition-colors duration-300">
             <span class="absolute w-3 h-0.5 bg-slate-400 group-open:bg-white transition-all"></span>
             <span class="absolute w-0.5 h-3 bg-slate-400 group-open:bg-white group-open:rotate-90 transition-all"></span>
          </div>
        </summary>

        <div class="px-6 pb-6 pt-2">
          <div class="text-slate-500 text-base leading-relaxed border-t border-slate-50 pt-6 animate-fadeIn">
            {faq.a}
          </div>
        </div>
      </details>
    ))}
  </div>
</section>

<style>
  /* Smooth open animation */
  details[open] .animate-fadeIn {
    animation: fadeIn 0.4s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
---
// src/components/sections/TechniquesGrid.astro
const topTechniques = [
    { id: '01', title: 'Gratitude Journaling', desc: "Focus on things you are grateful for, ideally 3-5 specific items. The power lies in vivid details rather than generic statements.", bestFor: "Anxiety, depression, and building optimism.", extraInfo: "Weekly entries often work better than rushed daily ones.", tags: ['Positivity', 'Mental Health'] },
    { id: '02', title: 'Morning Pages', desc: "Three pages of longhand, stream-of-consciousness writing done first thing in the morning to clear mental clutter.", bestFor: "Creatives, overthinkers, and clearing mental inbox.", extraInfo: "Do it before checking your phone.", tags: ['Creativity', 'Clarity'] },
    { id: '03', title: 'Bullet Journaling', desc: "A system of rapid logging using bullets to bridge personal organization and self-reflection.", bestFor: "Productivity, ADHD, and goal tracking.", extraInfo: "Acts as a planner and journal in one.", tags: ['Productivity', 'Organization'] },
    { id: '04', title: 'Stream of Consciousness', desc: "Unfiltered output where the pen never stops moving, capturing every thought in real-time.", bestFor: "Emotional processing and breaking creative blocks.", extraInfo: "Surfaces hidden thoughts.", tags: ['Self-Discovery', 'Relief'] },
    { id: '05', title: 'Expressive Writing', desc: "Writing about deepest thoughts related to emotional or traumatic experiences for 15-20 minutes.", bestFor: "Trauma, grief, and physical healing.", extraInfo: "Scientifically backed by Dr. James Pennebaker.", tags: ['Healing', 'Trauma'] },
    { id: '06', title: 'Dream Journaling', desc: "Recording dreams immediately upon waking to capture fragments and symbols before they fade.", bestFor: "Accessing the subconscious and creative inspiration.", extraInfo: "Keep a notebook right by your bed.", tags: ['Subconscious', 'Dreams'] }
];

// Masonry में 01, 02, 03 को बाजू-बाजू में दिखाने के लिए एरे को री-ऑर्डर करना पड़ता है
// क्योंकि columns पहले vertical भरता है।
const column1 = [topTechniques[0], topTechniques[3]];
const column2 = [topTechniques[1], topTechniques[4]];
const column3 = [topTechniques[2], topTechniques[5]];
const orderedTechniques = [...column1, ...column2, ...column3];
---

<section id="techniques" class="py-10 bg-[#fafafa] px-4">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-4xl font-bold text-gray-800 mb-4 tracking-tight">Types of Journaling Techniques</h2>
      <span class="inline-block bg-indigo-50 text-indigo-600 px-4 py-1 rounded-full text-xs font-semibold uppercase tracking-widest">
        📚 Core Techniques
      </span>
    </div>
    
    <div class="masonry-wrapper">
      {orderedTechniques.map(tech => (
        <div class="card-item group">
          <div class="bg-white rounded-[20px] p-8 flex flex-col relative z-10 border border-gray-100 hover:border-indigo-500/30 transition-all duration-500 shadow-sm hover:shadow-xl">
            
            <div class="flex-grow">
              <span class="text-[10px] font-black text-gray-400 tracking-[0.2em] uppercase mb-4 block group-hover:text-indigo-500 transition-colors leading-none">TECHNIQUE {tech.id}</span>
              <h3 class="text-2xl font-black text-gray-900 mb-4 leading-tight group-hover:text-indigo-600 transition-colors">{tech.title}</h3>
              
              <div class="relative overflow-hidden mb-6">
                <div class="content-text text-[13px] text-gray-500 leading-[1.7] font-medium transition-all duration-500 max-h-[100px] overflow-hidden">
                  <p class="mb-4">{tech.desc}</p>
                  <p class="italic text-gray-600 border-l-2 border-indigo-100 pl-4 py-1">{tech.extraInfo}</p>
                </div>
              </div>

              <div class="mb-6 p-4 bg-gray-50 rounded-xl border border-dashed border-gray-200">
                <span class="text-[9px] font-black uppercase tracking-widest text-gray-400 block mb-1">Best For</span>
                <p class="text-[12px] font-bold text-gray-700 leading-snug">{tech.bestFor}</p>
              </div>
            </div>

            <div class="mt-auto">
              <div class="flex flex-wrap gap-2 pt-4 mb-6 border-t border-gray-50">
                {tech.tags.map(tag => (
                  <span class="bg-gray-50 border border-gray-100 text-gray-500 text-[9px] uppercase font-bold px-3 py-1 rounded-lg">{tag}</span>
                ))}
              </div>

              <button class="read-more-btn w-full py-3.5 rounded-xl bg-indigo-600 text-white text-[11px] font-black uppercase tracking-widest hover:bg-indigo-700 shadow-md transition-all duration-300 flex items-center justify-center gap-2">
                <span>Read More</span>
                <svg class="w-3.5 h-3.5 transition-transform duration-300 arrow-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"></path></svg>
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-5 text-center">
      <a href="/techniques" class="inline-flex items-center gap-3 bg-indigo-600 text-white font-black text-[13px] px-75 py-5 rounded-full shadow-lg hover:scale-105 transition-all duration-300 uppercase tracking-widest group">
        <span>See All 48 Techniques</span>
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .masonry-wrapper {
    column-count: 3;
    column-gap: 2rem;
  }
  .card-item {
    break-inside: avoid;
    margin-bottom: 2rem;
    display: inline-block;
    width: 100%;
  }
  @media (max-width: 1024px) { .masonry-wrapper { column-count: 2; } }
  @media (max-width: 768px) { .masonry-wrapper { column-count: 1; } }

  .content-text {
    transition: max-height 0.5s ease;
  }
</style>

<script>
  const buttons = document.querySelectorAll('.read-more-btn');
  const allContentTexts = document.querySelectorAll('.content-text');
  const allArrows = document.querySelectorAll('.arrow-icon');
  const allBtnTexts = document.querySelectorAll('.read-more-btn span');

  buttons.forEach((btn, index) => {
    btn.addEventListener('click', () => {
      const currentText = allContentTexts[index] as HTMLElement;
      const currentArrow = allArrows[index] as HTMLElement;
      const currentBtnText = allBtnTexts[index] as HTMLElement;
      
      const isCurrentlyExpanded = currentText.style.maxHeight && currentText.style.maxHeight !== '100px';

      allContentTexts.forEach((text, i) => {
        if (i !== index) {
          (text as HTMLElement).style.maxHeight = '100px';
          (allArrows[i] as HTMLElement).style.transform = 'rotate(0deg)';
          (allBtnTexts[i] as HTMLElement).innerText = 'Read More';
        }
      });

      if (isCurrentlyExpanded) {
        currentText.style.maxHeight = '100px';
        currentBtnText.innerText = 'Read More';
        currentArrow.style.transform = 'rotate(0deg)';
      } else {
        currentText.style.maxHeight = currentText.scrollHeight + 'px';
        currentBtnText.innerText = 'Read Less';
        currentArrow.style.transform = 'rotate(180deg)';
      }
    });
  });
</script>
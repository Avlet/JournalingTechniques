---
// src/components/sections/TechniquesGrid.astro
const topTechniques = [
  { id: '01', title: 'Gratitude Journaling', desc: "Write 3-5 specific things you're grateful for. Specificity produces strongest results.", tags: ['Anxiety', 'Depression', 'Optimism'] },
  { id: '02', title: 'Morning Pages', desc: 'Three pages of stream-of-consciousness writing every morning before anything else.', tags: ['Writers', 'Artists', 'Overthinkers'] },
  { id: '03', title: 'Bullet Journaling', desc: 'Rapid-logging system for tasks, notes, events, habit trackers — every journal unique.', tags: ['Productivity', 'ADHD', 'Habit Building'] },
  { id: '04', title: 'Stream of Consciousness', desc: "Write exactly what's in your mind — no editing, no pausing. The pen never stops.", tags: ['Emotion Processing', 'Creative Blocks', 'Self-Discovery'] },
  { id: '05', title: 'Expressive Writing', desc: 'Most scientifically backed — 15-20 min for 3-4 days about deepest feelings on a difficult experience.', tags: ['Trauma', 'Grief', 'PTSD'] },
  { id: '06', title: 'Dream Journaling', desc: 'Record dreams immediately upon waking. Patterns reveal subconscious preoccupations.', tags: ['Creatives', 'Subconscious', 'Nightmares'] },
];
---
<section id="techniques" class="py-20 bg-[#fafafa] px-4">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-4xl font-bold text-gray-800 mb-4">Types of Journaling Techniques</h2>
      <span class="inline-block bg-indigo-50 text-indigo-600 px-4 py-1 rounded-full text-xs font-semibold">
        📚 48 Techniques
      </span>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {topTechniques.map(tech => (
        <div class="group relative p-[1px] rounded-[15px] bg-transparent hover:bg-gradient-to-br hover:from-indigo-500 hover:to-purple-600 transition-all duration-500 cursor-pointer shadow-sm hover:shadow-xl">
          <!-- Inner Card Body -->
          <div class="bg-white rounded-[15px] p-8 h-full flex flex-col justify-between relative z-10 transition-colors">
            <div>
              <span class="text-xs font-bold text-gray-400 tracking-wider uppercase mb-2 block group-hover:text-indigo-500 transition-colors">TECHNIQUE {tech.id}</span>
              <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:bg-gradient-to-r group-hover:from-indigo-600 group-hover:to-purple-600 group-hover:bg-clip-text group-hover:text-transparent transition-all">{tech.title}</h3>
              <p class="text-sm text-gray-500 mb-6 line-clamp-3 leading-relaxed">{tech.desc}</p>
            </div>
            <div class="flex flex-wrap gap-2">
              {tech.tags.map(tag => (
                <span class="bg-gray-50 border border-gray-100 text-gray-500 text-[10px] uppercase font-bold tracking-tight px-3 py-1 rounded-full group-hover:bg-indigo-50 group-hover:text-indigo-600 transition-colors">{tag}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <div class="mt-16 text-center">
      <!-- 3. Smart Link Button -->
      <a href="/techniques" class="inline-flex items-center gap-2 bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-bold text-sm px-10 py-4 rounded-full shadow-lg hover:shadow-indigo-200 hover:scale-105 transition-all duration-300 active:scale-95 uppercase tracking-wide">
        See All 48 Techniques
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>
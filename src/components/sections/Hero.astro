---
// src/components/sections/Hero.astro
---
<section class="pt-40 pb-20 text-center px-4 bg-[#fafafa]">
  <div class="max-w-3xl mx-auto">
    <div class="inline-block bg-blue-50 text-blue-600 border border-blue-100 px-4 py-1 rounded-full text-xs font-semibold tracking-wide mb-6 uppercase">
      <span class="text-blue-400 mr-1">•</span> 48+ Research Backed Techniques
    </div>
    
    <h1 class="text-6xl md:text-7xl font-bold text-gray-900 tracking-tight mb-4">
      Journaling <br />
      <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500">
        Techniques
      </span>
    </h1>
    
    <p class="text-lg text-gray-500 max-w-xl mx-auto mb-10 leading-relaxed">
      The complete guide to every method that actually works. Backed by peer-reviewed research. Organized by what you need right now.
    </p>
    
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="#all-techniques" class="bg-white border border-gray-200 text-gray-900 font-bold text-sm px-8 py-3.5 rounded-full shadow-sm hover:shadow-md transition flex items-center gap-2">
        EXPLORE ALL 48 TECHNIQUES <span class="text-lg">→</span>
      </a>
      <a href="#finder" class="bg-transparent border border-gray-200 text-gray-500 font-medium text-sm px-8 py-3.5 rounded-full hover:bg-gray-50 transition">
        FIND YOUR TECHNIQUE
      </a>
    </div>
  </div>
</section>
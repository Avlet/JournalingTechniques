---
// src/components/Footer.astro

const topTechniques = [
  { name: 'What Is Journaling', href: '/#what-is' },
  { name: 'What Research Shows', href: '/#research' },
  { name: 'The Benefits of Journaling', href: '/#benefits' },
  { name: 'Types of Journaling Techniques', href: '/#techniques' },
  { name: 'How to Start your Practice', href: '/#how-to-start' }
];

const latestArticles = [
  { 
    name: "Messagenal: A Practical Guide", 
    href: "/blog/messagenal-a-practical-guide-for-clear-messaging/", 
    img: "https://dev.journalingtechniques.org/wp-content/uploads/2026/02/Messagenal-2048x1249-1.webp" 
  },
  { 
    name: "Ottersec Lawsuit", 
    href: "/blog/ottersec-lawsuit-a-landmark-battle-over-blockchain-audit-governance/", 
    img: "https://dev.journalingtechniques.org/wp-content/uploads/2026/05/Ottersec-Lawsuit-2.webp" 
  },
  { 
    name: "Manifestation 101", 
    href: "/blog/manifestation-101-a-beginners-guide-to-vision-journaling-for-success/", 
    img: "https://dev.journalingtechniques.org/wp-content/uploads/2026/05/Manifestation-and-Vision-Journaling-scaled-1.webp" 
  }
];
---
<footer class="bg-[#0a0a0b] text-white pt-24 pb-12 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 mb-20">
      
     <div class="col-span-1 md:col-span-4">
  <a href="/" class="flex items-center gap-2 mb-8 group cursor-pointer">
    <div class="w-3 h-3 bg-indigo-500 rounded-full group-hover:scale-125 transition-transform"></div>
    <span class="font-bold text-xl tracking-tight">Journaling<span class="text-indigo-500">Techniques</span></span>
  </a>
  <p class="text-slate-400 text-sm leading-relaxed mb-6 max-w-sm">
    The complete guide to every method that actually works. Backed by research and designed for human growth.
  </p>
  
  <div class="flex items-center gap-3 group">
    <div class="w-8 h-8 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center group-hover:border-indigo-500/50 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-400"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
    </div>
    <a href="mailto:hello@journalingtechniques.org" class="text-sm text-slate-400 hover:text-white transition-colors font-medium">
      hello@journalingtechniques.org
    </a>
  </div>
</div>

      <div class="col-span-1 md:col-span-3">
        <h4 class="font-bold text-xs uppercase tracking-[0.2em] mb-8 text-slate-200">Top Techniques</h4>
        <ul class="space-y-4 text-sm">
           {topTechniques.map(tech => (
             <li><a href={tech.href} class="text-slate-500 hover:text-indigo-400 transition-colors">{tech.name}</a></li>
           ))}
        </ul>
      </div>

      <div class="col-span-1 md:col-span-3">
        <h4 class="font-bold text-xs uppercase tracking-[0.2em] mb-8 text-slate-200">Latest Articles</h4>
        <ul class="space-y-5">
           {latestArticles.map(article => (
             <li>
               <a href={article.href} class="flex items-center gap-3 group">
                 <div class="w-10 h-10 rounded-lg overflow-hidden flex-shrink-0 border border-white/5 shadow-inner shadow-white/10 group-hover:border-indigo-500/50 transition-all">
                    <img src={article.img} alt={article.name} class="w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-opacity" />
                 </div>
                 <span class="text-sm text-slate-500 group-hover:text-indigo-400 transition-colors leading-snug">
                   {article.name}
                 </span>
               </a>
             </li>
           ))}
        </ul>
      </div>

      <div class="col-span-1 md:col-span-2">
        <h4 class="font-bold text-xs uppercase tracking-[0.2em] mb-8 text-slate-200">Connect</h4>
        <ul class="space-y-4 text-sm">
           <li><a href="/about" class="text-slate-500 hover:text-indigo-400 transition-colors">About Us</a></li>
           <li><a href="/contact" class="text-slate-500 hover:text-indigo-400 transition-colors">Contact</a></li>
           <li class="pt-2">
              <span class="inline-flex items-center gap-2 px-3 py-1 bg-indigo-500/10 text-indigo-400 rounded-full text-[10px] font-bold uppercase tracking-tighter border border-indigo-500/20">
                Join Newsletter
              </span>
           </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-slate-900 pt-12 flex flex-col md:flex-row justify-between items-center gap-6">
        <div class="text-[11px] text-slate-600 tracking-wide uppercase">
          © 2026 <span class="text-slate-400">journalingtechniques.org</span> — ALL RESEARCH CITED.
        </div>
        
       
  </div>
</footer>
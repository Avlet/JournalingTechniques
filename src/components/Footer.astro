---
// src/components/Footer.astro
// Note: Make sure you have lucide-astro or similar installed, 
// or you can use the SVG paths provided below.
---
<footer class="bg-[#0a0a0b] text-white pt-24 pb-12 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 mb-20">
      
      <!-- Brand & About -->
      <div class="col-span-1 md:col-span-4">
        <div class="flex items-center gap-2 mb-8 group cursor-pointer">
           <div class="w-3 h-3 bg-indigo-500 rounded-full group-hover:scale-125 transition-transform"></div>
           <span class="font-bold text-xl tracking-tight">Journaling<span class="text-indigo-500">Techniques</span></span>
        </div>
        <p class="text-slate-400 text-sm leading-relaxed mb-8 max-w-sm">
          The complete guide to every method that actually works. Backed by research and designed for human growth.
        </p>
        
        <!-- Social Icons Fixed -->
        <div class="flex gap-4">
          {[
            { label: 'Twitter', path: 'M22 4s-1 1-2 1c1 1 2 2 2 4a8 8 0 0 1-2-1 4 4 0 0 0-7 3 11 11 0 0 1-8-4 4 4 0 0 0 1 5 4 4 0 0 1-2-1v.1a4 4 0 0 0 3 3.9 4 4 0 0 1-2 .1 4 4 0 0 0 4 2.8 8 8 0 0 1-10 1.1 11 11 0 0 0 6 1.8c7.2 0 11.1-6 11.1-11.1v-.5c.8-.6 1.4-1.3 2-2z' },
            { label: 'Instagram', path: 'M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z M17.5 6.5h.01' },
            { label: 'LinkedIn', path: 'M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z M2 9h4v12H2z M4 2a2 2 0 1 1-2 2 2 2 0 0 1 2-2z' }
          ].map((social) => (
            <a href="#" aria-label={social.label} class="w-10 h-10 rounded-xl border border-slate-800 flex items-center justify-center text-slate-500 hover:border-indigo-500 hover:text-indigo-500 hover:-translate-y-1 transition-all duration-300">
               <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                 <path d={social.path}></path>
                 {social.label === 'Instagram' && <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>}
               </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Quick Links Sections -->
      <div class="col-span-1 md:col-span-2">
        <h4 class="font-bold text-xs uppercase tracking-[0.2em] mb-8 text-slate-200">Techniques</h4>
        <ul class="space-y-4 text-sm">
           <li><a href="#" class="text-slate-500 hover:text-indigo-400 transition-colors">Self-Reflection</a></li>
           <li><a href="#" class="text-slate-500 hover:text-indigo-400 transition-colors">Growth & Goals</a></li>
           <li><a href="#" class="text-slate-500 hover:text-indigo-400 transition-colors">Specialized</a></li>
        </ul>
      </div>

      <div class="col-span-1 md:col-span-3">
        <h4 class="font-bold text-xs uppercase tracking-[0.2em] mb-8 text-slate-200">Resources</h4>
        <ul class="space-y-4 text-sm">
           <li><a href="#" class="text-slate-500 hover:text-indigo-400 transition-colors">Benefits of Journaling</a></li>
           <li><a href="#" class="text-slate-500 hover:text-indigo-400 transition-colors">Research & Studies</a></li>
           <li><a href="#" class="text-slate-500 hover:text-indigo-400 transition-colors">Digital vs Paper</a></li>
        </ul>
      </div>

      <div class="col-span-1 md:col-span-3">
        <h4 class="font-bold text-xs uppercase tracking-[0.2em] mb-8 text-slate-200">Connect</h4>
        <ul class="space-y-4 text-sm">
           <li><a href="#" class="text-slate-500 hover:text-indigo-400 transition-colors">About Us</a></li>
           <li><a href="#" class="text-slate-500 hover:text-indigo-400 transition-colors">Contact Support</a></li>
           <li class="pt-2">
              <span class="inline-flex items-center gap-2 px-3 py-1 bg-indigo-500/10 text-indigo-400 rounded-full text-[10px] font-bold uppercase tracking-tighter border border-indigo-500/20">
                Join Newsletter
              </span>
           </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-slate-900 pt-12 flex flex-col md:flex-row justify-between items-center gap-6">
        <div class="text-[11px] text-slate-600 tracking-wide uppercase">
          © 2026 <span class="text-slate-400">journalingtechniques.org</span> — ALL RESEARCH CITED.
        </div>
        
        <div class="flex items-center gap-6 text-[11px] text-slate-600 font-medium">
          <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
          <a href="#" class="hover:text-white transition-colors">Terms of Service</a>
          <span class="hidden md:block text-slate-800">|</span>
          <p class="flex items-center gap-1.5">
            Made with <span class="text-rose-500">❤️</span> in India
          </p>
        </div>
    </div>
  </div>
</footer>
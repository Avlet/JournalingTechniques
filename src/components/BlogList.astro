---
import Layout from '../layouts/BaseLayout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';

const { page, posts } = Astro.props;

// SEO logic: Page 1 के लिए आपका दिया हुआ Title, बाकी पेजों के लिए Page Number के साथ।
const seoTitle = page.currentPage === 1 
  ? "Journaling Blog – Tips, Techniques & Inspiration" 
  : `Journaling Blog - Page ${page.currentPage} - Journaling Techniques`;

const seoDescription = "Explore our blog for the latest journaling tips, writing prompts, and techniques. Whether you're a beginner or seasoned journaler, find something new to inspire your practice.";
---

<Layout title={seoTitle} description={seoDescription}>
  <Header />
  
  <main class="bg-[#fafafa] pt-32 pb-24 px-4">
    <div class="max-w-6xl mx-auto">
      
      <div class="max-w-2xl mb-20">
        <span class="inline-block bg-indigo-50 text-indigo-600 px-4 py-1 rounded-full text-[10px] font-black uppercase tracking-widest mb-4">
          Our Journal
        </span>
        <h1 class="text-5xl font-black text-slate-900 mb-6 tracking-tight">
          Journaling Insights
        </h1>
        <p class="text-slate-500 text-lg font-medium leading-relaxed">
          Explore science-backed thoughts on clarity, mindfulness, and the art of writing.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {posts.map((post) => (
          <article class="group bg-white/70 backdrop-blur-md rounded-[32px] p-4 border border-slate-100 hover:border-indigo-500/20 shadow-sm hover:shadow-xl transition-all duration-500">
            <a href={`/blog/${post.slug}`} class="block">
              <div class="relative aspect-[4/3] overflow-hidden rounded-[24px] bg-slate-100 mb-6">
                <img 
                  src={post.featuredImage?.node?.sourceUrl || 'https://via.placeholder.com/600x400?text=Journaling'} 
                  alt={post.title} 
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" 
                  loading="lazy"
                />
                <div class="absolute top-4 left-4">
                   <span class="bg-white/90 backdrop-blur-md text-slate-900 text-[9px] font-black uppercase px-3 py-1.5 rounded-lg shadow-sm">
                    {post.categories?.nodes[0]?.name || 'General'}
                  </span>
                </div>
              </div>
              
              <div class="px-2 pb-4">
                <time class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block mb-3">
                  {new Date(post.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                </time>

                <h2 class="text-xl font-black text-slate-900 leading-[1.3] mb-4 group-hover:text-indigo-600 transition-colors" set:html={post.title} />
                
                <div class="text-slate-500 text-sm leading-relaxed mb-6 line-clamp-3 font-medium" set:html={post.excerpt} />
                
                <div class="flex items-center gap-2 text-indigo-600 font-black text-[11px] uppercase tracking-wider">
                  Read Article
                  <div class="w-6 h-6 rounded-full bg-indigo-50 flex items-center justify-center group-hover:bg-indigo-600 group-hover:text-white transition-all duration-300">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
                  </div>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

      {posts.length === 0 && (
        <div class="text-center py-20">
          <p class="text-slate-400 font-bold">No posts found yet.</p>
        </div>
      )}

      <div class="mt-20 flex items-center justify-center gap-4">
        {page.url.prev ? (
          <a href={page.url.prev} class="flex items-center gap-2 px-6 py-3 bg-white/70 backdrop-blur-md border border-slate-100 rounded-2xl text-slate-600 font-black text-[11px] uppercase tracking-wider hover:border-indigo-500/20 hover:shadow-lg transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            Previous
          </a>
        ) : (
          <div class="flex items-center gap-2 px-6 py-3 bg-slate-50/50 border border-slate-100 rounded-2xl text-slate-300 font-black text-[11px] uppercase tracking-wider cursor-not-allowed">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            Previous
          </div>
        )}
        
        <div class="flex items-center gap-2 bg-white/50 backdrop-blur-sm px-4 py-2 rounded-2xl border border-slate-100">
            <span class="text-[11px] font-black text-slate-400 uppercase tracking-widest">Page</span>
            <span class="text-[11px] font-black text-indigo-600">{page.currentPage}</span>
            <span class="text-[11px] font-black text-slate-400 uppercase tracking-widest">of</span>
            <span class="text-[11px] font-black text-slate-900">{page.lastPage}</span>
        </div>

        {page.url.next ? (
          <a href={page.url.next} class="flex items-center gap-2 px-6 py-3 bg-white/70 backdrop-blur-md border border-slate-100 rounded-2xl text-slate-600 font-black text-[11px] uppercase tracking-wider hover:border-indigo-500/20 hover:shadow-lg transition-all duration-300">
            Next
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        ) : (
          <div class="flex items-center gap-2 px-6 py-3 bg-slate-50/50 border border-slate-100 rounded-2xl text-slate-300 font-black text-[11px] uppercase tracking-wider cursor-not-allowed">
            Next
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </div>
        )}
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;  
    overflow: hidden;
  }
</style>
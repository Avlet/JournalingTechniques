---
import BlogList from '../../components/BlogList.astro';

export async function getStaticPaths({ paginate }) {
  const API_URL = import.meta.env.WORDPRESS_API_URL;
  let allPosts = [];

  try {
    const response = await fetch(API_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        query: `
          query GetPosts {
            posts(first: 100) { 
              nodes {
                slug
                title
                excerpt
                date
                featuredImage {
                  node {
                    sourceUrl
                  }
                }
                categories {
                  nodes {
                    name
                  }
                }
              }
            }
          }
        `,
      }),
    });

    const json = await response.json();
    if (json.data && json.data.posts) {
      allPosts = json.data.posts.nodes;
    }
  } catch (e) {
    console.error('Fetch Error in getStaticPaths:', e);
  }

  return paginate(allPosts, { pageSize: 9 });
}

const { page } = Astro.props;
const posts = page.data;
---

<BlogList page={page} posts={posts} />

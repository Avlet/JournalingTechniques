---
import Layout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// .env से URL लेना
const API_URL = import.meta.env.WORDPRESS_API_URL;

let sortedPosts = [];
let error = null;

try {
  const response = await fetch(API_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      query: `
        query GetPosts {
          posts(first: 100) { 
            nodes {
              slug
              title
              excerpt
              date
              featuredImage {
                node {
                  sourceUrl
                  mediaDetails {
                    width
                    height
                  }
                }
              }
              categories {
                nodes {
                  name
                }
              }
            }
          }
        }
      `,
    }),
  });

  const json = await response.json();
  
  if (json.errors) {
    console.error('GraphQL Errors:', json.errors);
    error = "डेटा लोड करने में समस्या आई है।";
  } else {
    sortedPosts = json.data.posts.nodes;
  }
} catch (e) {
  console.error('Fetch Error:', e);
  error = "कनेक्शन फेल हो गया। कृपया .env चेक करें।";
}
---

<Layout title="Blog - Journaling Techniques">
  <Header />
  
  <main class="bg-[#fafafa] pt-32 pb-24 px-4">
    <div class="max-w-6xl mx-auto">
      
      <div class="max-w-2xl mb-20">
        <span class="inline-block bg-blue-50 text-blue-600 px-4 py-1 rounded-full text-[10px] font-black uppercase tracking-widest mb-4">
          Our Journal
        </span>
        <h1 class="text-5xl font-black text-slate-900 mb-6 tracking-tight">
          Journaling Insights
        </h1>
        <p class="text-slate-500 text-lg font-medium leading-relaxed">
          Explore science-backed thoughts on clarity, mindfulness, and the art of writing.
        </p>
      </div>

      {error && (
        <div class="bg-red-50 text-red-500 p-4 rounded-xl border border-red-100 mb-10">
          {error}
        </div>
      )}

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {sortedPosts.map((post) => (
          <article class="group bg-white rounded-[32px] p-4 border border-slate-100 hover:border-blue-500/20 shadow-sm hover:shadow-xl transition-all duration-500">
            <a href={`/blog/${post.slug}`} class="block">
              <div class="relative aspect-[4/3] overflow-hidden rounded-[24px] bg-slate-100 mb-6">
                <img 
                  src={post.featuredImage?.node?.sourceUrl || 'https://via.placeholder.com/600x400?text=Journaling'} 
                  alt={post.title} 
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" 
                  loading="lazy"
                />
                <div class="absolute top-4 left-4">
                   <span class="bg-white/90 backdrop-blur-md text-slate-900 text-[9px] font-black uppercase px-3 py-1.5 rounded-lg shadow-sm">
                    {post.categories?.nodes[0]?.name || 'General'}
                  </span>
                </div>
              </div>
              
              <div class="px-2 pb-4">
                <time class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block mb-3">
                  {new Date(post.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                </time>

                <h2 class="text-xl font-black text-slate-900 leading-[1.3] mb-4 group-hover:text-blue-600 transition-colors" set:html={post.title} />
                
                <div class="text-slate-500 text-sm leading-relaxed mb-6 line-clamp-3 font-medium" set:html={post.excerpt} />
                
                <div class="flex items-center gap-2 text-blue-600 font-black text-[11px] uppercase tracking-wider">
                  Read Article
                  <div class="w-6 h-6 rounded-full bg-blue-50 flex items-center justify-center group-hover:bg-blue-600 group-hover:text-white transition-all duration-300">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
                  </div>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

      {sortedPosts.length === 0 && !error && (
        <div class="text-center py-20">
          <p class="text-slate-400 font-bold">No posts found yet.</p>
        </div>
      )}
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;  
    overflow: hidden;
  }
</style>
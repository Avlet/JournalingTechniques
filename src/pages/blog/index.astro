---
// src/pages/blog/index.astro
import Layout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const API_URL = import.meta.env.WORDPRESS_API_URL;

const response = await fetch(API_URL, {
  method: 'POST',
  headers: { 'Content-Type': 'application/json' },
  body: JSON.stringify({
    query: `
      query GetPosts {
        posts(first: 20) {
          nodes {
            slug
            title
            excerpt
            date
            featuredImage {
              node {
                sourceUrl
              }
            }
            categories {
              nodes {
                name
              }
            }
          }
        }
      }
    `,
  }),
});

const json = await response.json();
const sortedPosts = json.data.posts.nodes;
---

<Layout title="Blog - Journaling Techniques">
  <Header />
  
  <main class="bg-white pt-32 pb-24">
    <div class="max-w-6xl mx-auto px-6">
      
      <!-- Minimal Header -->
      <div class="mb-16">
        <h1 class="text-4xl md:text-5xl font-black text-slate-900 mb-4 tracking-tight">
          Journaling Insights
        </h1>
        <div class="w-16 h-1 bg-blue-600 rounded-full mb-6"></div>
        <p class="text-slate-500 text-lg max-w-xl font-medium">
          Simple guides and science-backed thoughts on clarity and mindfulness.
        </p>
      </div>

      <!-- Simple & Modern Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16">
        {sortedPosts.map((post) => (
          <article class="group cursor-pointer">
            <a href={`/blog/${post.slug}`} class="block space-y-5">
              <!-- Image Container -->
              <div class="relative aspect-video overflow-hidden rounded-2xl bg-slate-50 border border-slate-100">
                <img 
                  src={post.featuredImage?.node?.sourceUrl || '/placeholder-image.jpg'} 
                  alt={post.title} 
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" 
                />
              </div>
              
              <!-- Content -->
              <div class="space-y-3">
                <div class="flex items-center gap-3">
                  <span class="text-[10px] font-bold uppercase tracking-[0.15em] text-blue-600">
                    {post.categories?.nodes[0]?.name || 'Journaling'}
                  </span>
                  <span class="w-1 h-1 rounded-full bg-slate-200"></span>
                  <time class="text-[11px] font-medium text-slate-400">
                    {new Date(post.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </time>
                </div>

                <h2 class="text-xl font-bold text-slate-900 leading-snug group-hover:text-blue-600 transition-colors" set:html={post.title} />
                
                <div class="text-slate-500 text-sm leading-relaxed line-clamp-2" set:html={post.excerpt} />
                
                <div class="pt-2 flex items-center gap-1 text-slate-900 font-bold text-[12px]">
                  Read More
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;  
    overflow: hidden;
  }
</style>
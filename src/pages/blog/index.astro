---
// src/pages/blog/index.astro
import { getCollection } from 'astro:content';
import Layout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// 1. Content Collection से सभी ब्लॉग पोस्ट्स लाएं
const allPosts = await getCollection('blog');

// 2. पोस्ट्स को तारीख के हिसाब से सॉर्ट करें (ताकि नई पोस्ट पहले दिखे)
const sortedPosts = allPosts.sort((a, b) => 
  b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
---

<Layout title="Our Blog - Journaling Techniques">
  <Header />
  
  <main class="bg-[#fafafa] pt-32 pb-24 px-6">
    <div class="max-w-6xl mx-auto">
      <!-- Blog Header -->
      <div class="text-center mb-20">
        <h1 class="text-5xl font-bold text-slate-800 mb-6">Journaling Insights</h1>
        <p class="text-slate-400 text-lg max-w-2xl mx-auto">गहराई से समझें जर्नलिंग के विज्ञान और कला को।</p>
      </div>

      <!-- Blog Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-10">
        {sortedPosts.map((post) => {
          // [slug].astro के साथ मैच करने के लिए slug जनरेट करें
          const slugValue = post.id.split('/').pop()?.replace(/\.[^/.]+$/, "") || post.id;

          return (
            <a href={`/blog/${slugValue}`} class="group bg-white rounded-[32px] overflow-hidden border border-slate-100 shadow-sm hover:shadow-xl transition-all duration-300">
              <div class="aspect-video overflow-hidden bg-slate-100">
                <img 
                  src={post.data.image} 
                  alt={post.data.title} 
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
                />
              </div>
              <div class="p-8">
                <div class="flex items-center gap-3 mb-4">
                  <span class="text-xs font-bold uppercase tracking-wider text-indigo-600 bg-indigo-50 px-3 py-1 rounded-full">
                    {post.data.category}
                  </span>
                  <span class="text-xs text-slate-300">
                    {post.data.publishedAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </span>
                </div>
                <h2 class="text-xl font-bold text-slate-800 mb-4 group-hover:text-indigo-600 transition-colors">
                  {post.data.title}
                </h2>
                <p class="text-slate-400 text-sm leading-relaxed line-clamp-3">
                  {post.data.description}
                </p>
                <div class="mt-8 flex items-center text-indigo-600 font-bold text-sm gap-2">
                  Read Article 
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </main>

  <Footer />
</Layout>
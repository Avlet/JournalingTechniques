---
import Layout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact Us - Journaling Techniques">
  <Header />
  
  <main class="bg-[#F9FAFB] pt-32 pb-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex flex-col lg:flex-row gap-16 items-center">
        
        <!-- Left Side: Info -->
        <div class="lg:w-1/2">
          <h1 class="text-5xl font-bold text-slate-900 mb-6">Let's Talk</h1>
          <p class="text-slate-500 text-lg mb-10">
            क्या आपके पास कोई सवाल है? या आप हमारे साथ अपनी जर्नलिंग स्टोरी शेयर करना चाहते हैं? हमें खुशी होगी!
          </p>
          
          <div class="space-y-6">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center shadow-sm border border-slate-100">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-indigo-600"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
              </div>
              <span class="text-slate-600 font-medium">hiren@link-builder.online</span>
            </div>
          </div>
        </div>

        <!-- Right Side: Form -->
        <div class="lg:w-1/2 w-full">
          <form class="bg-white rounded-[40px] p-10 border border-slate-100 shadow-xl shadow-indigo-100/20 space-y-6">
            <div>
              <label class="block text-sm font-bold text-slate-700 mb-2">Name</label>
              <input type="text" placeholder="Your Name" class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-transparent focus:border-indigo-500 focus:bg-white outline-none transition-all" />
            </div>
            <div>
              <label class="block text-sm font-bold text-slate-700 mb-2">Email</label>
              <input type="email" placeholder="email@example.com" class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-transparent focus:border-indigo-500 focus:bg-white outline-none transition-all" />
            </div>
            <div>
              <label class="block text-sm font-bold text-slate-700 mb-2">Message</label>
              <textarea rows="4" placeholder="How can we help?" class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-transparent focus:border-indigo-500 focus:bg-white outline-none transition-all"></textarea>
            </div>
            <button class="w-full bg-indigo-600 text-white font-bold py-4 rounded-2xl hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-100">
              Send Message
            </button>
          </form>
        </div>

      </div>
    </div>
  </main>

  <Footer />
</Layout>
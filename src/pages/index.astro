---
// src/pages/index.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import Layout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

// Core Sections (Ensure these exist in src/components/sections/)
import Hero from '../components/sections/Hero.astro';
import WhatIs from '../components/sections/WhatIs.astro';
import Research from '../components/sections/Research.astro';
import Benefits from '../components/sections/Benefits.astro';
import TechniquesGrid from '../components/sections/TechniquesGrid.astro';
import HowToStartJournaling from '../components/sections/HowToStartJournaling.astro';
import Prompts from '../components/sections/Prompts.astro';
import TimePlace from '../components/sections/TimePlace.astro';
import Comparison from '../components/sections/Comparison.astro';
import Mistakes from '../components/sections/Mistakes.astro';
import Consistency from '../components/sections/Consistency.astro';
import FAQ from '../components/sections/FAQ.astro';
import FinalTakeaway from '../components/sections/FinalTakeaway.astro';

import Footer from '../components/Footer.astro';
---

const title = "Journaling Techniques – Learn How to Journal Effectively";
const description = "Discover powerful journaling techniques to boost clarity, reduce stress, and grow personally. Start your journaling journey today with expert tips and guides.";

<BaseLayout title={title} description={description}>
  
  <Header />
  
  <main class="bg-[#fafafa] min-h-screen">
    
    <Hero />
    
    <WhatIs />
    
    <Research />
    
    <Benefits />
    
    <TechniquesGrid />
    
    <HowToStartJournaling />
    
    <Prompts />
    
    <TimePlace />
    
    <Comparison />
    
    <Mistakes />
    
    <Consistency />
    
    <FAQ />
    
    <FinalTakeaway />
    
  </main>

  <Footer />

</BaseLayout>
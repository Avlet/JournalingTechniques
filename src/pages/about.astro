---
import Layout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About Us - Journaling Techniques">
  <Header />
  
  <main class="bg-[#F9FAFB] pt-32 pb-24">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16">
        <span class="text-indigo-600 font-bold uppercase tracking-widest text-xs">Our Story</span>
        <h1 class="text-5xl font-bold text-slate-900 mt-4 mb-6">Why we started journaling</h1>
        <p class="text-slate-500 text-lg leading-relaxed">
          Journaling is not just about writing words on paper; it is a journey of self-discovery. We started this blog to help those who want to untangle and understand their thoughts
        </p>
      </div>

      <div class="bg-white rounded-[40px] p-10 md:p-16 border border-slate-100 shadow-sm">
        <h2 class="text-3xl font-bold text-slate-800 mb-6">The Mission</h2>
        <p class="text-slate-500 mb-8 leading-relaxed">
        Our goal is to make journaling simple and accessible. Whether you want to reduce stress or enhance your creativity, we have something for everyone
        </p>
        
        <div class="grid md:grid-cols-2 gap-8 mt-12">
          <div class="p-8 bg-indigo-50 rounded-3xl">
            <h3 class="font-bold text-indigo-900 mb-2">Clarity</h3>
            <p class="text-indigo-700/70 text-sm">Clearing your thoughts and achieving mental peace</p>
          </div>
          <div class="p-8 bg-slate-50 rounded-3xl">
            <h3 class="font-bold text-slate-900 mb-2">Growth</h3>
            <p class="text-slate-500 text-sm">Taking a step each day toward becoming a better version of yourself.</p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>